APP_NAME=Book Factory
APP_ENV=development
SECRET_KEY=change-me-super-secret-long-random-string
DATABASE_URL=sqlite:///./book_factory.db
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-me-now

# LM Studio (lokalny model - primary provider)
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_API_KEY=sk-lm-zUq6F9wh:laEUNufmmlgpbnsz4CI2
LM_STUDIO_MODEL=gemma-3-27b-it

# Google Gemini fallback
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GOOGLE_MODEL=gemini-2.5-flash

# OpenRouter fallback
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/auto

# Timeout w sekundach (LLM może być wolny przy dużych modelach)
REQUEST_TIMEOUT_SECONDS=120
